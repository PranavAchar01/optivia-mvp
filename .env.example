# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# LiteLLM proxy (Optivia runs this internally)
LITELLM_MASTER_KEY=sk-optivia-...

# Database (Neon Postgres)
DATABASE_URL=postgresql+asyncpg://user:pass@host/optivia

# Redis (Upstash)
REDIS_URL=redis://default:pass@host:6379
# Redis connection components (used by LiteLLM config separately from REDIS_URL)
REDIS_HOST=host
REDIS_PASSWORD=pass

# Langfuse observability
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# Voyage AI (embeddings)
VOYAGE_API_KEY=pa-...

# JWT secret for API auth
JWT_SECRET=change-me-in-production

# Environment
ENV=development

# Token budget (W) per session — default 200k
SESSION_TOKEN_BUDGET=200000

# Optivia API base (used by CLI)
OPTIVIA_API_BASE=http://localhost:8000
